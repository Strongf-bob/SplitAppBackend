HOST_PORT=8080
MONGODB_DB_NAME=splitapp
MONGODB_AUTH_SOURCE=admin
MONGODB_TLS=false
JWT_SECRET=change-me-generate-a-long-random-value
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=30
JWT_REFRESH_REUSE_GRACE_SECONDS=120
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://split-app.ru
SENTRY_DSN=
METRICS_ACCESS_TOKEN=change-me-generate-a-long-random-value

# Grafana binds to localhost by default to avoid exposing operations data.
# Use an SSH tunnel or a reverse proxy with authentication for remote access.
GRAFANA_BIND_ADDRESS=127.0.0.1
GRAFANA_HOST_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-generate-a-long-random-value

# Optional public Grafana URL. When set on the server, deploy starts the
# public-grafana Compose profile and exposes only Grafana through HTTPS.
# Prometheus, Loki and /api/metrics stay private.
GRAFANA_PUBLIC_DOMAIN=grafana.split-app.ru
GRAFANA_PUBLIC_HTTP_PORT=80
GRAFANA_PUBLIC_HTTPS_PORT=443

# Optional Yandex Object Storage settings. Receipt image endpoints return a
# configuration error until S3_BUCKET and credentials are set.
S3_ENDPOINT_URL=https://storage.yandexcloud.net
S3_REGION=ru-central1
YC_OBJECT_STORAGE_ACCESS_KEY_ID=
YC_OBJECT_STORAGE_SECRET_ACCESS_KEY=
S3_BUCKET=
