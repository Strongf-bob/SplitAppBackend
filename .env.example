MONGODB_URI=
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_HOSTS=
MONGODB_USER=
MONGODB_PASSWORD=
MONGODB_AUTH_SOURCE=splitapp
MONGODB_REPLICA_SET=
MONGODB_TLS=false
MONGODB_TLS_CA_FILE=
MONGODB_DB_NAME=splitapp
JWT_SECRET=
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=30
JWT_REFRESH_REUSE_GRACE_SECONDS=120
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://split-app.ru
SENTRY_DSN=
METRICS_ACCESS_TOKEN=change-me-generate-a-long-random-value

# Optional APNs push notifications. Use APNS_PRIVATE_KEY or APNS_PRIVATE_KEY_PATH.
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_BUNDLE_ID=
APNS_PRIVATE_KEY=
APNS_PRIVATE_KEY_PATH=

GRAFANA_BIND_ADDRESS=127.0.0.1
GRAFANA_HOST_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-generate-a-long-random-value

# Yandex Object Storage (S3-compatible). When both are set, passed explicitly to session.client().
S3_ENDPOINT_URL=https://storage.yandexcloud.net
S3_REGION=ru-central1
YC_OBJECT_STORAGE_ACCESS_KEY_ID=
YC_OBJECT_STORAGE_SECRET_ACCESS_KEY=
S3_BUCKET=
