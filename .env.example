MONGODB_URI=
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_HOSTS=
MONGODB_USER=
MONGODB_PASSWORD=
MONGODB_AUTH_SOURCE=splitapp
MONGODB_REPLICA_SET=
MONGODB_TLS=false
MONGODB_TLS_CA_FILE=
MONGODB_DB_NAME=splitapp
JWT_SECRET=
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=30
JWT_REFRESH_REUSE_GRACE_SECONDS=120
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://split-app.ru
SENTRY_DSN=
METRICS_ACCESS_TOKEN=change-me-generate-a-long-random-value

# Splitik LLM provider (OpenAI-compatible chat completions).
SPLITIK_LLM_BASE_URL=
SPLITIK_LLM_API_KEY=
SPLITIK_PRIMARY_MODEL=
SPLITIK_FAST_CHAT_MODEL=deepseek-v4-flash
SPLITIK_TEXT_MODEL_POOL=deepseek-v4-flash,kimi-k2.6
SPLITIK_FAST_CHAT_TIMEOUT_SECONDS=8
SPLITIK_INTENT_MODEL=deepseek-v4-flash
SPLITIK_INTENT_TIMEOUT_SECONDS=8
SPLITIK_VISION_MODEL=minimax-m3
SPLITIK_VISION_MODEL_POOL=minimax-m3,qwen3.7-plus
SPLITIK_MODEL_QUARANTINE_SECONDS=600
# Optional private, anonymized real receipt fixture used by the 10-minute vision probe.
SPLITIK_VISION_SMOKE_IMAGE_URL=
SPLITIK_VISION_SMOKE_EXPECTED_TOTAL_KOPECKS=
SPLITIK_VISION_TIMEOUT_SECONDS=20
SPLITIK_VERIFICATION_MODEL=
SPLITIK_ESCALATION_MODEL=
SPLITIK_LLM_TIMEOUT_SECONDS=12

GRAFANA_BIND_ADDRESS=127.0.0.1
GRAFANA_HOST_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-generate-a-long-random-value

# Yandex Object Storage (S3-compatible). When both are set, passed explicitly to session.client().
S3_ENDPOINT_URL=https://storage.yandexcloud.net
S3_REGION=ru-central1
YC_OBJECT_STORAGE_ACCESS_KEY_ID=
YC_OBJECT_STORAGE_SECRET_ACCESS_KEY=
S3_BUCKET=
